# Normalmente NO hace falta un terraform.tfvars: el sitio tiene un solo
# ambiente (producción) y los valores reales ya están como default en
# variables.tf. El backend del state está en S3 (ver backend.tf), también
# fijo.
#
# Este archivo solo sirve si quieres probar localmente apuntando a otro
# dominio/certificado. Cópialo a terraform.tfvars (gitignored) y ajusta:
#
# domain_aliases      = ["mi-dominio-de-prueba.example.com"]
# acm_certificate_arn = "arn:aws:acm:us-east-1:000000000000:certificate/..."
#
# Para usar solo el dominio *.cloudfront.net por defecto, deja la lista
# vacía y el ARN en string vacío:
#
# domain_aliases      = []
# acm_certificate_arn = ""
